# ============================================================================
# BELLEYA - SUPABASE CONFIGURATION EXAMPLE
# ============================================================================
#
# Ce fichier est un exemple de configuration pour le projet Belleya.
#
# INSTRUCTIONS:
# 1. Copier ce fichier vers .env
# 2. Remplacer les valeurs XXXXX par vos vraies credentials Belleya
# 3. Ne JAMAIS commit le fichier .env (il doit être dans .gitignore)
#
# ============================================================================

# Project URL (à récupérer dans Settings > API de votre projet Belleya)
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Anon Key (clé publique - à récupérer dans Settings > API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Project identifier (pour identification dans les logs)
VITE_PROJECT_NAME=Belleya

# Environment (development, staging, production)
VITE_ENV=development

# ============================================================================
# MAPBOX CONFIGURATION
# ============================================================================
#
# Mapbox est utilise pour afficher les cartes (page prestataires, adresse)
#
# OBTENIR UN TOKEN:
# 1. Aller sur https://account.mapbox.com/access-tokens/
# 2. Creer un compte gratuit si necessaire
# 3. Cliquer sur "Create a token"
# 4. Nom: "Belleya Production" (ou similaire)
# 5. Scopes OBLIGATOIRES:
#    - styles:read (lire les styles de carte)
#    - tiles:read (charger les tuiles de carte)
#    - fonts:read (charger les polices)
# 6. URL restrictions: LAISSER VIDE pour eviter l'erreur 401
#    OU ajouter tous vos domaines (localhost, bolt.new, netlify, vercel, etc.)
# 7. Copier le token (commence par pk.)
#
VITE_MAPBOX_TOKEN=pk.xxxxx

# ============================================================================
# NOTES IMPORTANTES
# ============================================================================
#
# 1. SÉPARATION COMPLÈTE AVEC CLIENTPULSE
#    - Ne PAS utiliser les credentials de ClientPulse
#    - Belleya doit avoir son propre projet Supabase
#    - Aucune donnée utilisateur n'est partagée entre les deux projets
#
# 2. SÉCURITÉ
#    - Ne JAMAIS exposer la service_role key côté frontend
#    - La service_role key doit rester dans Supabase Edge Functions
#    - Seule l'anon key peut être utilisée côté client
#
# 3. VÉRIFICATION
#    Au démarrage, vous devriez voir dans la console:
#    ╔═══════════════════════════════════════════════════════════════╗
#    ║ 🚀 Supabase Project: Belleya                                  ║
#    ║ 🌐 URL: https://xxxxx.supabase.co                            ║
#    ║ 🛠️  Environment: development                                  ║
#    ╚═══════════════════════════════════════════════════════════════╝
#
# ============================================================================
